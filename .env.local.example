# ========================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ========================================
# Copy this to .env.local and fill in your values
# .env.local is git-ignored and used for local development only

# Server
NODE_ENV=development
LOG_LEVEL=debug

# ========================================
# Database Configuration
# ========================================
# Option 1: Use local Postgres (recommended for development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vertiaccess"

# Option 2: Use external RDS (if available)
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@your-db-proxy.proxy-region.rds.amazonaws.com:5432/vertiaccess?sslmode=require"

# ========================================
# AWS Configuration (Local Development Only)
# ========================================
# For production, use IAM roles - DO NOT store credentials in .env
AWS_REGION="us-east-2"

# Only use if running Lambda functions locally
AWS_ACCESS_KEY_ID="your_local_key_here"
AWS_SECRET_ACCESS_KEY="your_local_secret_here"

# ========================================
# Stripe Configuration
# ========================================
# Get from: https://dashboard.stripe.com/apikeys (Restricted to test mode)
STRIPE_SECRET_KEY="sk_test_your_test_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"
BOOKING_CHARGE_KEY="your_booking_charge_key_here"

# ========================================
# Cognito Configuration
# ========================================
# These are created by SST during deployment
# For local development, you can create a local Cognito user pool or use test values
COGNITO_USER_POOL_ID="us-east-2_xxxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"

# ========================================
# Default Admin (Local Development Only)
# ========================================
# IMPORTANT: Change these for production deployment!
# See DEPLOYMENT_CHECKLIST.md for production values
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="LocalPassword123!"
DEFAULT_ADMIN_FIRST_NAME="Local"
DEFAULT_ADMIN_LAST_NAME="Admin"

# ========================================
# CORS Origins (Local Development)
# ========================================
# For production, SST automatically includes deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# S3 Configuration (Local Development Only)
# ========================================
# These are created by SST during deployment
S3_BUCKET_NAME="your_s3_bucket_name"
